{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"color": "#f4f1de",
					"name": "Base",
					"slug": "base"
				},
				{
					"color": "#3d405b",
					"name": "Contrast",
					"slug": "contrast"
				},
				{
					"color": "#e07a5f",
					"name": "Accent",
					"slug": "accent"
				},
				{
					"color": "#81b29a",
					"name": "Accent Alt",
					"slug": "accent-alt"
				},
				{
					"color": "#f2cc8f",
					"name": "Highlight",
					"slug": "highlight"
				},
				{
					"color": "#fbf8ef",
					"name": "Surface",
					"slug": "surface"
				},
				{
					"color": "#696d84",
					"name": "Muted",
					"slug": "muted"
				},
				{
					"color": "rgba(61,64,91,0.14)",
					"name": "Border",
					"slug": "border"
				}
			]
		},
		"custom": {
			"motion": {
				"fast": "180ms",
				"base": "360ms"
			}
		},
		"layout": {
			"contentSize": "720px",
			"wideSize": "1280px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "2XS",
					"size": "0.5rem",
					"slug": "20"
				},
				{
					"name": "XS",
					"size": "0.875rem",
					"slug": "30"
				},
				{
					"name": "S",
					"size": "1.25rem",
					"slug": "40"
				},
				{
					"name": "M",
					"size": "clamp(1.5rem, 2vw, 2rem)",
					"slug": "50"
				},
				{
					"name": "L",
					"size": "clamp(2rem, 3vw, 3rem)",
					"slug": "60"
				},
				{
					"name": "XL",
					"size": "clamp(3rem, 5vw, 4.5rem)",
					"slug": "70"
				},
				{
					"name": "2XL",
					"size": "clamp(4rem, 7vw, 6rem)",
					"slug": "80"
				}
			],
			"units": [
				"%",
				"px",
				"rem",
				"vw",
				"vh"
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": true,
			"fontFamilies": [
				{
					"name": "Figtree",
					"slug": "figtree",
					"fontFamily": "\"Figtree\", sans-serif"
				},
				{
					"name": "Fraunces",
					"slug": "fraunces",
					"fontFamily": "\"Fraunces\", serif"
				}
			],
			"fontSizes": [
				{
					"name": "Small",
					"size": "0.875rem",
					"slug": "small"
				},
				{
					"name": "Medium",
					"size": "1rem",
					"slug": "medium"
				},
				{
					"name": "Large",
					"size": "clamp(1.2rem, 1.1rem + 0.7vw, 1.5rem)",
					"slug": "large"
				},
				{
					"name": "XL",
					"size": "clamp(1.9rem, 1.5rem + 2vw, 3rem)",
					"slug": "x-large"
				},
				{
					"name": "2XL",
					"size": "clamp(2.6rem, 2rem + 3vw, 4.75rem)",
					"slug": "xx-large"
				}
			],
			"lineHeight": true
		}
	},
	"styles": {
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|contrast"
		},
		"spacing": {
			"blockGap": "1.5rem",
			"padding": {
				"left": "var:preset|spacing|50",
				"right": "var:preset|spacing|50"
			}
		},
		"typography": {
			"fontFamily": "var:preset|font-family|figtree",
			"fontSize": "var:preset|font-size|medium",
			"fontWeight": "400",
			"lineHeight": "1.6"
		},
		"blocks": {
			"core/button": {
				"border": {
					"radius": "0"
				},
				"variations": {
					"outline": {
						"border": {
							"color": "currentColor",
							"style": "solid",
							"width": "1px"
						},
						"spacing": {
							"padding": {
								"bottom": "0.9rem",
								"left": "1.5rem",
								"right": "1.5rem",
								"top": "0.9rem"
							}
						}
					}
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var:preset|font-size|small",
					"fontWeight": "600",
					"letterSpacing": "0.02em",
					"textTransform": "uppercase"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var:preset|font-family|figtree"
				}
			},
			"core/query-title": {
				"typography": {
					"fontFamily": "var:preset|font-family|figtree"
				}
			},
			"core/search": {
				"css": "& .wp-block-search__input { border-radius: 0; border-color: var(--wp--preset--color--border); padding-inline: 1rem; min-height: 52px; }"
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var:preset|font-family|figtree",
					"fontSize": "var:preset|font-size|large",
					"fontWeight": "800",
					"letterSpacing": "-0.05em"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"woocommerce/product-price": {
				"typography": {
					"fontSize": "var:preset|font-size|medium",
					"fontWeight": "700"
				}
			}
		},
		"elements": {
			"button": {
				"border": {
					"radius": "0"
				},
				"color": {
					"background": "var:preset|color|contrast",
					"text": "var:preset|color|base"
				},
				"spacing": {
					"padding": {
						"bottom": "0.9rem",
						"left": "1.5rem",
						"right": "1.5rem",
						"top": "0.9rem"
					}
				},
				":hover": {
					"color": {
						"background": "color-mix(in srgb, var(--wp--preset--color--contrast) 88%, transparent)"
					}
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|figtree",
					"fontWeight": "800",
					"lineHeight": "0.98",
					"letterSpacing": "-0.06em"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|xx-large"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|x-large"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|large"
				}
			},
			"link": {
				"color": {
					"text": "currentColor"
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "header",
			"name": "checkout-header",
			"title": "Checkout Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	]
}
